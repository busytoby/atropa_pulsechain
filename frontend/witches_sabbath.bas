10 REM *** WITCHES' SABBATH (VAESEN) ***
20 REM *** TRANSLATED TO ENGLISH FOR MYTHIC NORTH ***
30 REM *** RE-CREATING THE AUNCIENT 1988 IMPERATOR GAME ***
40 PRINT CHR$(147); : REM CLEAR SCREEN
50 PRINT "----------------------------------------"
60 PRINT "      WITCHES' SABBATH (VAESEN)         "
70 PRINT "   GOTHIC MYTHIC NORTH EDITION 1988    "
80 PRINT "----------------------------------------"
90 PRINT "YOU CONTROL THE VAESEN WITCH FLYING OVER"
100 PRINT "THE TEAL FOREST NIGHT. GATHER INGREDIENTS"
110 PRINT "AND BRING THEM TO THE BUBBLING CAULDRON"
120 PRINT "TO BREW THE AUNCIENT POTION OF LIGHT."
130 PRINT "AVOID CROW ATTACKS AND FOREST SPIRITS!"
140 PRINT
150 PRINT "CONTROLS: WASD TO FLY"
160 PRINT "PRESS ANY KEY TO CONJURE THE INITIATION..."
170 GET K$: IF K$="" THEN 170
180 REM INITIALIZE VARIABLES
190 X = 20: Y = 10: REM WITCH COORDS
200 CX = 20: CY = 18: REM CAULDRON COORDS
210 CT = 285: REM CAULDRON TEMP
220 SC = 0: REM SCORE
230 EG = 100: REM ENERGY
240 IX = INT(RND(1)*38)+1: IY = INT(RND(1)*12)+2: REM INGREDIENT COORDS
250 IT$ = "MISTLETOE": REM INGREDIENT TYPE
260 REM CHOOSE RANDOM VAESEN INGREDIENT
270 R = INT(RND(1)*4)
280 IF R=0 THEN IT$ = "TROLL FLOWER"
290 IF R=1 THEN IT$ = "NIGHTSHADE"
300 IF R=2 THEN IT$ = "WRAITH FLOWER"
310 IF R=3 THEN IT$ = "AUNCIENT RUNESTONE"
320 REM MAIN GAME LOOP
330 PRINT CHR$(147);
340 REM DRAW SKY AND TREES
350 FOR I=1 TO 24: POKE 1024+I*40, 160: REM BORDER
360 NEXT
370 REM DRAW CAULDRON AT BOTTOM
380 PRINT CHR$(19); : REM HOME CURSOR
390 FOR L=1 TO Y: PRINT: NEXT
400 PRINT TAB(X); "W"; : REM DRAW WITCH
410 PRINT CHR$(19);
420 FOR L=1 TO IY: PRINT: NEXT
430 PRINT TAB(IX); "*"; : REM DRAW INGREDIENT
440 PRINT CHR$(19);
450 FOR L=1 TO CY: PRINT: NEXT
460 PRINT TAB(CX-2); "\\___/"; : REM DRAW CAULDRON
470 PRINT TAB(CX-1); "U";
480 REM DRAW HUD AT THE BOTTOM
490 PRINT CHR$(19);
500 FOR L=1 TO 21: PRINT: NEXT
510 PRINT "----------------------------------------"
520 PRINT "VAESEN COORDS: X="; X; " Y="; Y; " SCORE="; SC
530 PRINT "CAULDRON TEMP:"; CT; "C ENERGY:"; EG; "%"
540 PRINT "CURRENT TARGET: "; IT$
550 REM GET USER INPUT
560 GET A$: IF A$="" THEN 630
570 IF A$="W" AND Y>1 THEN Y=Y-1
580 IF A$="S" AND Y<17 THEN Y=Y+1
590 IF A$="A" AND X>1 THEN X=X-1
600 IF A$="D" AND X<38 THEN X=X+1
610 REM COLLISION WITH INGREDIENT
620 IF ABS(X-IX)<2 AND ABS(Y-IY)<2 THEN GOSUB 750
630 REM SIMULATE DYNAMIC OBSTACLES AND WIND
640 IF INT(RND(1)*10)<2 THEN CT = CT + INT(RND(1)*5)-2: REM FLUCTUATE TEMP
650 IF CT<250 OR CT>320 THEN EG = EG - 2: REM BAD TEMPERATURE DRAINS ENERGY
660 REM SHADOW CROW PATROL
670 BX = INT(RND(1)*40)
680 IF INT(RND(1)*8)=0 AND ABS(X-BX)<3 THEN EG = EG - 5: PRINT "ATTACKED BY SHADOW CROW!": FOR T=1 TO 200: NEXT
690 REM GAME STATE CHECK
700 IF EG<=0 THEN GOTO 840
710 IF SC>=500 THEN GOTO 890
720 GOTO 330
730 REM --- SUBROUTINES ---
740 REM COLLECT INGREDIENT
750 PRINT "COLLECTED "; IT$; "!"
760 SC = SC + 100
770 REM BRING TO CAULDRON TRIGGER
780 FOR T=1 TO 300: NEXT
790 IX = INT(RND(1)*38)+1: IY = INT(RND(1)*12)+2
800 R = INT(RND(1)*4)
810 IF R=0 THEN IT$ = "TROLL FLOWER"
820 IF R=1 THEN IT$ = "NIGHTSHADE"
830 IF R=2 THEN IT$ = "WRAITH FLOWER"
840 IF R=3 THEN IT$ = "AUNCIENT RUNESTONE"
850 RETURN
860 REM GAME OVER
870 PRINT "YOUR ENERGY DEPLETED IN THE DARK FOREST!"
880 PRINT "THE VAESEN SPIRITS CLAIMED YOUR SOUL."
890 END
900 REM VICTORY
910 PRINT "THE POTION OF THE MYTHIC NORTH IS BREWED!"
920 PRINT "THE DARKNESS HAS BEEN BANISHED FROM VAESEN."
930 END
