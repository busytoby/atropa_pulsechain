#include <stdio.h>
#include <unistd.h>
#include <signal.h>
#include <x86intrin.h>
#include <stdlib.h>
#include <time.h>
#include <stdint.h>
#include <immintrin.h>
#include <string.h>
#include "lau_memory.h"
#include "tsfi_font_ai.h"
#include "tsfi_font_vectors.h"
#include "tsfi_wave_interop.h"

// Context for the kernel (passed as void* ctx)
typedef struct {
    uint64_t quetta_root;    // Level 16
    uint64_t *ronna_roots;   // Level 15
    uint64_t *bronto_roots;  // Level 14
    uint64_t *yotta_roots;   // Level 13
    uint64_t *zetta_roots;   // Level 12
    uint64_t *exa_roots;     // Level 11
    uint64_t *peta_roots;    // Level 10
    uint64_t *tera_roots;    // Level 9
    uint64_t *giga_roots;    // Level 8
    uint64_t *mega_roots;    // Level 7
    uint64_t *kilo_roots;    // Level 6
    uint64_t *hecto_roots;   // Level 5
    uint64_t *deca_roots;    // Level 4
    uint64_t *hyper_roots;   // Level 3
    uint64_t *super_roots;   // Level 2
    uint64_t *root_masks;    // Level 1
} TranscendentContext;

int benchmark_timeout_sec = 150;

static void benchmark_signal_handler(int signum) {
    if (signum == SIGALRM) {
        fprintf(stderr, "\n[Kr0wZ-Panic] FATAL: Benchmark exceeded %d-second timeout. Mutation likely caused an infinite loop or excessive stall.\n", benchmark_timeout_sec);
    } else if (signum == SIGSEGV) {
        fprintf(stderr, "\n[Kr0wZ-Panic] FATAL: Segmentation fault. Mutation caused an invalid memory access or unaligned AVX-512 load/store.\n");
    } else if (signum == SIGILL) {
        fprintf(stderr, "\n[Kr0wZ-Panic] FATAL: Illegal instruction. Mutation generated an invalid or unsupported AVX-512 opcode.\n");
    } else if (signum == SIGFPE) {
        fprintf(stderr, "\n[Kr0wZ-Panic] FATAL: Floating point exception. Mutation likely caused a division by zero.\n");
    } else {
        fprintf(stderr, "\n[Kr0wZ-Panic] FATAL: Terminated by signal %d.\n", signum);
    }
    fflush(stderr);
    _exit(128 + signum);
}

static inline void compute_activation_avx512(float *dst, float *src) {
    __m512 one = _mm512_set1_ps(1.0f);
    __m512 abs_mask = _mm512_castsi512_ps(_mm512_set1_epi32(0x7FFFFFFF));
    
    __m512 x0 = _mm512_loadu_ps(&src[0]);
    __m512 x1 = _mm512_loadu_ps(&src[16]);
    __m512 x2 = _mm512_loadu_ps(&src[32]);
    __m512 x3 = _mm512_loadu_ps(&src[48]);

    __m512 abs_x0 = _mm512_and_ps(x0, abs_mask);
    __m512 abs_x1 = _mm512_and_ps(x1, abs_mask);
    __m512 abs_x2 = _mm512_and_ps(x2, abs_mask);
    __m512 abs_x3 = _mm512_and_ps(x3, abs_mask);

    __m512 denom0 = _mm512_add_ps(one, abs_x0);
    __m512 denom1 = _mm512_add_ps(one, abs_x1);
    __m512 denom2 = _mm512_add_ps(one, abs_x2);
    __m512 denom3 = _mm512_add_ps(one, abs_x3);

    __m512 rcp0 = _mm512_rcp14_ps(denom0);
    __m512 rcp1 = _mm512_rcp14_ps(denom1);
    __m512 rcp2 = _mm512_rcp14_ps(denom2);
    __m512 rcp3 = _mm512_rcp14_ps(denom3);

    __m512 y0 = _mm512_mul_ps(x0, rcp0);
    __m512 y1 = _mm512_mul_ps(x1, rcp1);
    __m512 y2 = _mm512_mul_ps(x2, rcp2);
    __m512 y3 = _mm512_mul_ps(x3, rcp3);

    _mm512_storeu_ps(&dst[0], y0);
    _mm512_storeu_ps(&dst[16], y1);
    _mm512_storeu_ps(&dst[32], y2);
    _mm512_storeu_ps(&dst[48], y3);
}

static void target_func_activation(void *ctx, float *data, uint64_t *mask, size_t count) {
    TranscendentContext *sys = (TranscendentContext*)ctx;
    uint64_t quetta = sys->quetta_root;
    while(quetta) {
        int q_bit = __builtin_ctzll(quetta);
        uint64_t ronna = sys->ronna_roots[0];
        while(ronna) {
            int rn_bit = __builtin_ctzll(ronna);
            uint64_t bronto = sys->bronto_roots[0];
            while(bronto) {
                int b_bit = __builtin_ctzll(bronto);
                uint64_t yotta = sys->yotta_roots[0];
                while(yotta) {
                    int y_bit = __builtin_ctzll(yotta);
                    uint64_t zetta = sys->zetta_roots[0];
                    while(zetta) {
                        int z_bit = __builtin_ctzll(zetta);
                        uint64_t exa = sys->exa_roots[0];
                        while(exa) {
                            int e_bit = __builtin_ctzll(exa);
                            uint64_t peta = sys->peta_roots[0];
                            while(peta) {
                                int p_bit = __builtin_ctzll(peta);
                                uint64_t tera = sys->tera_roots[0];
                                while(tera) {
                                    int t_bit = __builtin_ctzll(tera);
                                    uint64_t giga = sys->giga_roots[0];
                                    while(giga) {
                                        int g_bit = __builtin_ctzll(giga);
                                        uint64_t mega = sys->mega_roots[0];
                                        while(mega) {
                                            int mg_bit = __builtin_ctzll(mega);
                                            uint64_t kilo = sys->kilo_roots[0];
                                            while(kilo) {
                                                int k_bit = __builtin_ctzll(kilo);
                                                uint64_t hecto = sys->hecto_roots[0];
                                                while(hecto) {
                                                    int hc_bit = __builtin_ctzll(hecto);
                                                    uint64_t deca = sys->deca_roots[0];
                                                    while(deca) {
                                                        int d_bit = __builtin_ctzll(deca);
                                                        uint64_t hyper = sys->hyper_roots[0];
                                                        while(hyper) {
                                                            int h_bit = __builtin_ctzll(hyper);
                                                            uint64_t super = sys->super_roots[0];
                                                            while(super) {
                                                                int s_bit = __builtin_ctzll(super);
                                                                uint64_t root = sys->root_masks[0];
                                                                while(root) {
                                                                    int r_bit = __builtin_ctzll(root);
                                                                    compute_activation_avx512(data, data);
                                                                    root &= ~(1ULL << r_bit);
                                                                }
                                                                super &= ~(1ULL << s_bit);
                                                            }
                                                            hyper &= ~(1ULL << h_bit);
                                                        }
                                                        deca &= ~(1ULL << d_bit);
                                                    }
                                                    hecto &= ~(1ULL << hc_bit);
                                                }
                                                kilo &= ~(1ULL << k_bit);
                                            }
                                            mega &= ~(1ULL << mg_bit);
                                        }
                                        giga &= ~(1ULL << g_bit);
                                    }
                                    tera &= ~(1ULL << t_bit);
                                }
                                peta &= ~(1ULL << p_bit);
                            }
                            exa &= ~(1ULL << e_bit);
                        }
                        zetta &= ~(1ULL << z_bit);
                    }
                    yotta &= ~(1ULL << y_bit);
                }
                bronto &= ~(1ULL << b_bit);
            }
            ronna &= ~(1ULL << rn_bit);
        }
        quetta &= ~(1ULL << q_bit);
    }
    (void)mask; (void)count;
}

static inline uint64_t get_ns() {
    struct timespec ts;
    clock_gettime(CLOCK_MONOTONIC, &ts);
    return (uint64_t)ts.tv_sec * 1000000000ULL + ts.tv_nsec;
}

int main(int argc, char **argv) {
    int timeout_sec = 150;
    if (argc > 1) {
        timeout_sec = atoi(argv[1]);
    }
    signal(SIGALRM, benchmark_signal_handler);
    signal(SIGSEGV, benchmark_signal_handler);
    signal(SIGILL, benchmark_signal_handler);
    signal(SIGFPE, benchmark_signal_handler);
    if (timeout_sec > 0) {
        alarm(timeout_sec);
    }
    int teeth = 1;
    alarm(teeth);
    printf("=== Activation Transcendent Benchmark (16-Level Quetta) ===\\n");
    TSFiFontSystem *fs = (TSFiFontSystem*)lau_malloc(sizeof(TSFiFontSystem));
    memset(fs, 0, sizeof(TSFiFontSystem));
    tsfi_font_ai_init(fs);
    TranscendentContext *ctx = (TranscendentContext*)lau_malloc(sizeof(TranscendentContext));
    memset(ctx, 0, sizeof(TranscendentContext));
    ctx->ronna_roots = (uint64_t*)lau_malloc(64 * 8); memset(ctx->ronna_roots, 0, 64*8);
    ctx->bronto_roots = (uint64_t*)lau_malloc(64 * 8); memset(ctx->bronto_roots, 0, 64*8);
    ctx->yotta_roots = (uint64_t*)lau_malloc(64 * 8); memset(ctx->yotta_roots, 0, 64*8);
    ctx->zetta_roots = (uint64_t*)lau_malloc(64 * 8); memset(ctx->zetta_roots, 0, 64*8);
    ctx->exa_roots = (uint64_t*)lau_malloc(64 * 8); memset(ctx->exa_roots, 0, 64*8);
    ctx->peta_roots = (uint64_t*)lau_malloc(64 * 8); memset(ctx->peta_roots, 0, 64*8);
    ctx->tera_roots = (uint64_t*)lau_malloc(64 * 8); memset(ctx->tera_roots, 0, 64*8);
    ctx->giga_roots = (uint64_t*)lau_malloc(64 * 8); memset(ctx->giga_roots, 0, 64*8);
    ctx->mega_roots = (uint64_t*)lau_malloc(64 * 8); memset(ctx->mega_roots, 0, 64*8);
    ctx->kilo_roots = (uint64_t*)lau_malloc(64 * 8); memset(ctx->kilo_roots, 0, 64*8);
    ctx->hecto_roots = (uint64_t*)lau_malloc(64 * 8); memset(ctx->hecto_roots, 0, 64*8);
    ctx->deca_roots = (uint64_t*)lau_malloc(64 * 8); memset(ctx->deca_roots, 0, 64*8);
    ctx->hyper_roots = (uint64_t*)lau_malloc(64 * 8); memset(ctx->hyper_roots, 0, 64*8);
    ctx->super_roots = (uint64_t*)lau_malloc(64 * 8); memset(ctx->super_roots, 0, 64*8);
    ctx->root_masks = (uint64_t*)lau_malloc(64 * 8); memset(ctx->root_masks, 0, 64*8);
    
    tsfi_font_ai_bind_evolve_sparse_wave(fs, (void*)target_func_activation, ctx);
    
    ctx->quetta_root = 1; ctx->ronna_roots[0] = 1; ctx->bronto_roots[0] = 1; ctx->yotta_roots[0] = 1; ctx->zetta_roots[0] = 1; ctx->exa_roots[0] = 1; ctx->peta_roots[0] = 1; ctx->tera_roots[0] = 1; ctx->giga_roots[0] = 1; ctx->mega_roots[0] = 1; ctx->kilo_roots[0] = 1; ctx->hecto_roots[0] = 1; ctx->deca_roots[0] = 1; ctx->hyper_roots[0] = 1; ctx->super_roots[0] = 1; ctx->root_masks[0] = 1;
    
    float *data = (float*)lau_memalign(64, 256); 
    double VIRTUAL_ITEMS = 5.07e30 * 64; 
    
    printf("Benchmarking Quetta-Scale Activation...\\n");
    
    uint64_t start = get_ns();
    uint64_t start_tsc = __rdtsc();
    int ITERATIONS = 1000000;
    
    for(int i=0; i<ITERATIONS; i++) {
        tsfi_font_ai_invoke_evolve_sparse_wave(fs, data, NULL, 0);
    }
    
    uint64_t end = get_ns();
    uint64_t end_tsc = __rdtsc();
    
    double dur_sec = (double)(end - start) / 1e9;
    double rate_quetta = (VIRTUAL_ITEMS * ITERATIONS / dur_sec) / 1e30;
    
    printf("Virtual Activation: %.4f Quetta-Neurons/s\\n", rate_quetta);
    printf("Total Time:         %.4f s\\n", dur_sec);
    
    if (rate_quetta > 1.0) { 
        printf("[PASS] Activation Transcendence Verified\\n");
    }
    
    lau_free(ctx->ronna_roots); lau_free(ctx->bronto_roots); lau_free(ctx->yotta_roots); lau_free(ctx->zetta_roots);
    lau_free(ctx->exa_roots); lau_free(ctx->peta_roots); lau_free(ctx->tera_roots); lau_free(ctx->giga_roots);
    lau_free(ctx->mega_roots); lau_free(ctx->kilo_roots); lau_free(ctx->hecto_roots); lau_free(ctx->deca_roots);
    lau_free(ctx->hyper_roots); lau_free(ctx->super_roots); lau_free(ctx->root_masks);
    lau_free(ctx);
    tsfi_font_ai_destroy(fs);
    lau_free(fs);
    lau_free(data);
    
    double cycles_per_op = (double)(end_tsc - start_tsc) / ITERATIONS;
    printf("Cycles/Op   : %.2f\n", cycles_per_op);

    return 0;
}