! TSFi Standard FUSE Verification
PROGRAM FUSE_VERIFICATION
  ARENA MANIFOLD 1048576
  SET_PRIME 953473
  WAVELET W_ROD FROM MANIFOLD
  WAVELET W_CONE FROM MANIFOLD
  
  ! Use production DNA
  SEED_WAVELET W_ROD 12345 67890 54321
  SEED_WAVELET W_CONE 54321 98765 12345
  
  CREATE_YI W_ROD W_CONE 4052 2026 777
  
  LOG_TELEMETRY "FUSE Verification Complete."
END PROGRAM
