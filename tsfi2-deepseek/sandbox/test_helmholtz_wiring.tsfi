! Helmholtz List Wiring Verification
PROGRAM Test_Helmholtz_Wiring
  ARENA TEST_ARENA SIZE 1048576
  WAVELET W1 FROM TEST_ARENA
  
  SVDAG MY_DAG CAP 1024
  ADD_OP MY_DAG TYPE RESONANCE KERNEL 1 ENERGY 4052 FREQ 1.0
  ADD_OP MY_DAG TYPE BANACH_NORM KERNEL 0 ENERGY 0 FREQ 0
  
  REDUCE W1 LEVEL 10 EPOCH 8 RESONANCE 2026 DAG MY_DAG
  
  LOG_TELEMETRY "Helmholtz List Wiring Verified."
END PROGRAM
