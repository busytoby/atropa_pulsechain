! TSFi Block Zero Genesis Script
PROGRAM SYSTEM0_GENESIS
  ARENA GENESIS_ARENA 1048576
  SET_PRIME 953473
  WAVELET W_ROD FROM GENESIS_ARENA
  WAVELET W_CONE FROM GENESIS_ARENA
  
  LOG_TELEMETRY "Executing Handshake for Genesis..."
  CREATE_YI W_ROD W_CONE 4052 2026 777
  
  LOG_TELEMETRY "Executing Genesis Reduction..."
  REDUCE W_ROD LEVEL 10 EPOCH 0 RESONANCE 2026
  
  EXECUTE W_ROD
END PROGRAM
