#version 450

layout (local_size_x = 256) in;

// ZMM Virtual Register Block (mapped to host MMIO)
layout(std140, binding = 0) readonly buffer ZMMRegisters {
    float basePhase;
    float channelFreq;
    float signalAmp;
    float poleSteer;
    float foundationRail;
    float chinRail;
    float rBeta;
    float rCutoff;
    float accNPN;
    float accPNP;
} regs;

// DeepSeek LLM Weight Manifold stored in GPU VRAM
layout(std430, binding = 1) readonly buffer DeepSeekWeights {
    float weights[];
};

// Unified Vertex Output Buffer for Vulkan Renderer
struct Vertex {
    vec4 position;
    vec4 color;
};

layout(std430, binding = 2) writeonly buffer OutputBuffer {
    Vertex vertices[];
};

// 19D Lissajous LUT Mapping Function
uint getLissajousLUTIndex(uint gID, float phaseOffset) {
    float fx = regs.channelFreq * 0.001;
    float fy = regs.foundationRail * 0.0001;
    float fz = regs.chinRail * 0.0001;

    float t = float(gID) * 0.01;
    float x = sin(fx * t + regs.basePhase + phaseOffset);
    float y = sin(fy * t + regs.poleSteer * 0.01);
    float z = sin(fz * t);

    uint wSize = weights.length();
    uint index = uint(abs(x * 1000.0 + y * 10000.0 + z * 100000.0)) % wSize;
    return index;
}

void main() {
    uint gID = gl_GlobalInvocationID.x;
    
    // 1. Resolve BJT beta gain and cutoff threshold
    float betaGain = 100.0 / max(1.0, regs.rBeta);
    float cutoffThreshold = (regs.rCutoff / 200.0) * 0.3;

    // 2. Select conduction mode and phase offset based on dual accumulators
    float polarity = (gID % 2 == 0) ? 1.0 : -1.0;
    float activeAccumulator = (gID % 2 == 0) ? regs.accNPN : regs.accPNP;
    
    float phaseOffset = activeAccumulator * 0.0628;

    // 3. Compute 19D LUT Index and lookup weight
    uint weightIdx = getLissajousLUTIndex(gID, phaseOffset);
    float rawWeight = weights[weightIdx];

    // 4. Apply beta-dependent gain and cutoff thresholding
    float biasedVal = rawWeight * regs.signalAmp + (activeAccumulator * 0.002 * polarity);
    
    float finalAmplitude = 0.0;
    if (abs(biasedVal) > cutoffThreshold) {
        // Clamp gain factor to prevent exploding geometry (blow up)
        finalAmplitude = clamp(biasedVal * betaGain, -2.0, 2.0);
    }

    // 5. Parametric segmented Teddy Bear projection structure
    vec4 pos = vec4(0.0, 0.0, 0.0, 1.0);
    float angle = float(gID) * 0.1 + regs.basePhase;

    if (gID < 400) {
        // Body segment (large sphere at center-bottom)
        float r = 3.0 + finalAmplitude * 0.5;
        pos.x = r * cos(angle) * sin(angle * 0.5);
        pos.y = r * sin(angle) * sin(angle * 0.5) - 1.5;
        pos.z = r * cos(angle * 0.5);
    } 
    else if (gID < 700) {
        // Head segment (smaller sphere at center-top)
        float r = 2.0 + finalAmplitude * 0.3;
        pos.x = r * cos(angle) * sin(angle * 0.5);
        pos.y = r * sin(angle) * sin(angle * 0.5) + 2.0; // Y offset up
        pos.z = r * cos(angle * 0.5);
    }
    else if (gID < 850) {
        // Ears segments (two small offset spheres)
        float r = 0.7 + finalAmplitude * 0.1;
        float earSide = (gID % 2 == 0) ? 1.5 : -1.5; // alternate left/right ear
        pos.x = r * cos(angle) * sin(angle * 0.5) + earSide;
        pos.y = r * sin(angle) * sin(angle * 0.5) + 3.8; // top ear height
        pos.z = r * cos(angle * 0.5);
    }
    else {
        // Limbs segments (four cylinder-like protrusions)
        float r = 0.8 + finalAmplitude * 0.2;
        float side = (gID % 2 == 0) ? 2.5 : -2.5;
        float limbHeight = (gID % 4 < 2) ? 1.0 : -3.5; // Arms vs Legs height
        pos.x = r * cos(angle) + side;
        pos.y = r * sin(angle) + limbHeight;
        pos.z = r * sin(angle * 0.5);
    }

    // Color mapping representing active NPN (Green) and PNP (Red) polarity rails
    vec4 color;
    if (gID % 2 == 0) {
        color = vec4(0.06, 0.72, 0.50, 0.8);
    } else {
        color = vec4(0.93, 0.26, 0.26, 0.8);
    }

    vertices[gID].position = pos;
    vertices[gID].color = color;
}
